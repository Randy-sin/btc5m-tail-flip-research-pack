# Never commit a real .env file.
# Rotate any token or key that has ever been pasted into chat.

# Before Apr 28 2026 cutover, use clob-v2 only for integration testing unless Polymarket confirms real production support.
POLY_HOST=https://clob-v2.polymarket.com
# After Apr 28 2026 cutover, production V2 should be:
# POLY_HOST=https://clob.polymarket.com

POLY_CHAIN_ID=137
POLY_PRIVATE_KEY=0xREPLACE_ME
POLY_FUNDER_ADDRESS=0xREPLACE_ME
# 0=EOA, 1=POLY_PROXY Magic Link, 2=GNOSIS_SAFE / browser wallet proxy
POLY_SIGNATURE_TYPE=2

# Optional existing L2 creds. If omitted, script can derive via L1 wallet where supported.
POLY_CLOB_API_KEY=
POLY_CLOB_SECRET=
POLY_CLOB_PASSPHRASE=

# Probe guardrails
PROBE_ORDER_PRICE=0.01
PROBE_ORDER_SIZE_SHARES=100
PROBE_MAX_DAILY_RISK_USD=20
PROBE_CANCEL_AFTER_SECONDS=30
